import { MongoClient } from "mongodb";

const DB_NAME = process.env.DB_NAME || "app";
const USERS = "users";

let client;

export async function connectMongo() {
  if (client) return client;

  const uri = process.env.MONGODB_URI;
  if (!uri) throw new Error("Missing MONGODB_URI");

  client = new MongoClient(uri, {
    serverSelectionTimeoutMS: 10000,
  });

  await client.connect();

  console.log("Mongo connected");

  return client;
}

function db() {
  if (!client) throw new Error("Mongo not connected");
  return client.db(DB_NAME);
}

function users() {
  return db().collection(USERS);
}

export async function getUser(discordId) {
  return users().findOne({ discordId }).catch(err => {
    console.error("getUser error:", err);
    return null;
  });
}

export async function isVerified(discordId) {
  return Boolean(await getUser(discordId));
}

export async function getRoblox(discordId) {
  const user = await getUser(discordId);
  return user?.robloxUsername || user?.robloxId || null;
}

export async function getUserByRoblox(robloxUsername) {
  return users().findOne({ robloxUsername }).catch(err => {
    console.error("getUserByRoblox error:", err);
    return null;
  });
}
